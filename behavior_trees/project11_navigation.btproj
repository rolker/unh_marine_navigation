<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4" project_name="project11_navigation">
    <include path="navigator.xml"/>
    <!-- Description of Node Models (used by Groot) -->
    <TreeNodesModel>
        <Action ID="AdjustPath">
            <output_port name="adjusted_cross_track_error" default="{adjusted_cross_track_error}" type="double">Cross-track error on adjusted segment</output_port>
            <output_port name="adjusted_current_segment" default="{adjusted_current_segment}" type="int">Current segment of the adjusted path</output_port>
            <output_port name="adjusted_segment_count" default="{adjusted_segment_count}" type="int">Number of segment in adjusted path</output_port>
            <output_port name="adjusted_path" default="{adjusted_path}" type="std::shared_ptr&lt;std::vector&lt;geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt;, std::allocator&lt;geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt; &gt; &gt; &gt;">Path modified to avoid obstacles</output_port>
            <input_port name="local_costmap" default="{local_costmap}" type="std::shared_ptr&lt;project11_navigation::OccupancyGrid&gt;">Local costmap used to adjust trajectory</input_port>
            <input_port name="odometry" default="{odometry}" type="nav_msgs::msg::Odometry_&lt;std::allocator&lt;void&gt; &gt;">Robot's current odometry state</input_port>
            <input_port name="turn_radius" default="{turn_radius}" type="double">Robot's turn radius</input_port>
            <input_port name="tf_buffer" default="{tf_buffer}" type="std::shared_ptr&lt;tf2_ros::Buffer&gt;">Transform buffer</input_port>
            <input_port name="along_track_progress" default="{current_segment_along_track_progress}" type="double">How far along the current segment we are</input_port>
            <input_port name="current_segment" default="{current_segment}" type="int">Current path segment being followed</input_port>
            <output_port name="adjusted_along_track_progress" default="{adjusted_along_track_progress}" type="double">Progress along adjusted segment</output_port>
            <input_port name="path" default="{path}" type="std::shared_ptr&lt;std::vector&lt;geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt;, std::allocator&lt;geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt; &gt; &gt; &gt;">Path needing adjustment</input_port>
        </Action>
        <Condition ID="AllTasksDoneCondition">
            <input_port name="task_list" default="{task_list}" type="std::shared_ptr&lt;project11_navigation::TaskList&gt;">List of tasks to check</input_port>
        </Condition>
        <Action ID="BaxevaniController">
            <output_port name="command_velocity" default="{command_velocity}" type="geometry_msgs::msg::TwistStamped_&lt;std::allocator&lt;void&gt; &gt;">Output commanded velocity</output_port>
            <input_port name="delta" default="0.1" type="double">Distance of the (sonar) sensor from the center of mass/position of imu</input_port>
            <input_port name="maximum_dt" default="0.5" type="double">Maximum time step</input_port>
            <input_port name="px_gain" default="100.78" type="double">Proportional gain for the x axis</input_port>
            <input_port name="ricatti_parameter" default="1.8752285" type="double">Ricatti parameter</input_port>
            <input_port name="pw_gain" default="20.055" type="double">Proportional gain for the w axis</input_port>
            <input_port name="target_speed" default="{target_speed}" type="double">Target speed</input_port>
            <input_port name="tf_buffer" default="{tf_buffer}" type="std::shared_ptr&lt;tf2_ros::Buffer&gt;">Transform buffer</input_port>
            <input_port name="current_navigation_segment" default="{current_navigation_segment}" type="int">Current segment of the path to follow</input_port>
            <input_port name="odometry" default="{odometry}" type="nav_msgs::msg::Odometry_&lt;std::allocator&lt;void&gt; &gt;">Robot's current odometry state</input_port>
            <input_port name="navigation_path" default="{navigation_path}" type="std::shared_ptr&lt;std::vector&lt;geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt;, std::allocator&lt;geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt; &gt; &gt; &gt;">Path to follow</input_port>
        </Action>
        <Action ID="CCOMPlanner" editable="true">
            <input_port name="start_pose" default="{start_pose}"/>
            <input_port name="goal_pose" default="{goal_pose}"/>
            <output_port name="navigation_path" default="{navigation_path}"/>
            <input_port name="turn_radius" default="{robot_turn_radius}"/>
            <input_port name="tf_buffer" default="{tf_buffer}"/>
            <input_port name="context" default="{context}"/>
            <input_port name="speed" default="{robot_default_speed}"/>
        </Action>
        <Action ID="ClearPath">
            <output_port name="navigation_path" default="{navigation_path}" type="std::shared_ptr&lt;std::vector&lt;geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt;, std::allocator&lt;geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt; &gt; &gt; &gt;">Empty shared pointer to a path to follow</output_port>
        </Action>
        <Action ID="CrabbingPathFollower">
            <inout_port name="pid" default="{path_follower_pid}" type="std::shared_ptr&lt;project11::PID&gt;">PID controller for crabbing</inout_port>
            <output_port name="command_velocity" default="{command_velocity}" type="geometry_msgs::msg::TwistStamped_&lt;std::allocator&lt;void&gt; &gt;">Output commanded velocity</output_port>
            <input_port name="piloting_mode" default="{piloting_mode}" type="std::string">Piloting mode</input_port>
            <input_port name="target_speed" default="{target_speed}" type="double">Target speed</input_port>
            <input_port name="tf_buffer" default="{tf_buffer}" type="std::shared_ptr&lt;tf2_ros::Buffer&gt;">Transform buffer</input_port>
            <input_port name="current_navigation_segment" default="{current_navigation_segment}" type="int">Current segment of the path</input_port>
            <input_port name="odometry" default="{odometry}" type="nav_msgs::msg::Odometry_&lt;std::allocator&lt;void&gt; &gt;">Robot's current odometry state</input_port>
            <input_port name="navigation_path" default="{navigation_path}" type="std::shared_ptr&lt;std::vector&lt;geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt;, std::allocator&lt;geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt; &gt; &gt; &gt;">Path to follow</input_port>
        </Action>
        <Action ID="DebugBlackboardDouble">
            <input_port name="value" type="double">Value to print in the ROS log</input_port>
            <input_port name="message" default="message" type="std::string">Message to print, such as the variable name</input_port>
        </Action>
        <Action ID="DebugBlackboardString">
            <input_port name="value" type="std::string">Value to print in the ROS log</input_port>
            <input_port name="message" default="message" type="std::string">Message to print, such as the variable name</input_port>
        </Action>
        <Action ID="GeneratePlan">
            <output_port name="navigation_trajectory" default="{navigation_trajectory}" type="std::shared_ptr&lt;std::vector&lt;geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt;, std::allocator&lt;geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt; &gt; &gt; &gt;">Planned path to follow</output_port>
            <input_port name="lead_in_distance" default="{lead_in_distance}" type="double">Distance in meters to lead into lines</input_port>
            <output_port name="current_navigation_segment" default="{current_navigation_segment}" type="int">Index of the current segment of the navigation trajectory</output_port>
            <input_port name="turn_radius" default="{robot_turn_radius}" type="double">Turn radius for the robot</input_port>
            <input_port name="planner" default="{default_planner}" type="std::string">Planner to use</input_port>
            <input_port name="goal_pose" default="{goal_pose}" type="geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt;">Goal pose for the plan</input_port>
            <input_port name="start_pose" default="{current_pose}" type="geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt;">Starting pose for the plan</input_port>
        </Action>
        <Action ID="GetSubTasks">
            <output_port name="sub_tasks" default="{current_sub_tasks}" type="std::shared_ptr&lt;project11_navigation::TaskList&gt;">Sub tasks of the input task</output_port>
            <input_port name="task" default="{current_task}" type="std::shared_ptr&lt;project11_navigation::Task&gt;">Task to get sub tasks from</input_port>
        </Action>
        <Action ID="GetTaskDataDouble">
            <output_port name="value" type="double"/>
            <input_port name="default_value" type="double"/>
            <input_port name="key" type="std::string"/>
            <input_port name="task" default="{task}" type="std::shared_ptr&lt;project11_navigation::Task&gt;">Task to get data from</input_port>
        </Action>
        <Action ID="GetTaskDataString">
            <output_port name="value" type="std::string"/>
            <input_port name="default_value" type="std::string"/>
            <input_port name="key" type="std::string"/>
            <input_port name="task" default="{task}" type="std::shared_ptr&lt;project11_navigation::Task&gt;">Task to get data from</input_port>
        </Action>
        <Condition ID="GoalReachedCondition">
            <input_port name="heading_accuracy" default="180" type="double">How much can the heading can vary in degrees. 180 means it doesn't matter.</input_port>
            <input_port name="waypoint_reached_distance" default="{waypoint_reached_distance}" type="double">Distance in meters to consider the waypoint reached</input_port>
            <input_port name="goal_pose" default="{goal_pose}" type="geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt;">Pose to compare current state with</input_port>
            <input_port name="odometry" default="{odometry}" type="nav_msgs::msg::Odometry_&lt;std::allocator&lt;void&gt; &gt;">Robot's current odometry state</input_port>
        </Condition>
        <Action ID="Hover">
            <input_port name="marker_array" default="{marker_array}" type="std::shared_ptr&lt;visualization_msgs::msg::MarkerArray_&lt;std::allocator&lt;void&gt; &gt; &gt;">Marker array to add visualization markers to</input_port>
            <input_port name="goal_pose" default="{goal_pose}" type="geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt;">Goal pose for the robot</input_port>
            <input_port name="tf_buffer" default="{tf_buffer}" type="std::shared_ptr&lt;tf2_ros::Buffer&gt;">Transform buffer</input_port>
            <input_port name="maximum_speed" default="{hover_maximum_speed}" type="double">Maximum speed to use to get to the target</input_port>
            <input_port name="maximum_distance" default="{hover_maximum_distance}" type="double">Distance at which robot uses maximum speed to get to the target</input_port>
            <input_port name="minimum_distance" default="{hover_minimum_distance}" type="double">Distance within which robot is deemed at the target</input_port>
            <output_port name="command_velocity" default="{command_velocity}" type="geometry_msgs::msg::TwistStamped_&lt;std::allocator&lt;void&gt; &gt;">Output commanded velocity</output_port>
            <input_port name="odometry" default="{odometry}" type="nav_msgs::msg::Odometry_&lt;std::allocator&lt;void&gt; &gt;">Robot's current odometry state</input_port>
        </Action>
        <Action ID="MultibeamCoverageActionCancel">
            <input_port name="action_client" default="{multibeam_coverage_action_client}" type="std::shared_ptr&lt;project11_navigation::MultibeamCoverageActionClient&gt;">Multibeam coverage action client</input_port>
        </Action>
        <Condition ID="MultibeamCoverageActionDoneCondition">
            <input_port name="action_client" default="{multibeam_coverage_action_client}" type="std::shared_ptr&lt;project11_navigation::MultibeamCoverageActionClient&gt;">Multibeam coverage action client</input_port>
        </Condition>
        <Action ID="MultibeamCoverageActionSetGoal">
            <output_port name="action_client" default="{multibeam_coverage_action_client}" type="std::shared_ptr&lt;project11_navigation::MultibeamCoverageActionClient&gt;">Multibeam coverage action client</output_port>
            <input_port name="ros_action" type="std::string"/>
            <input_port name="task" default="{task}" type="std::shared_ptr&lt;project11_navigation::Task&gt;">Survey area Task describing area to survey</input_port>
        </Action>
        <Action ID="MultibeamCoverageActionUpdateTask">
            <input_port name="task" default="{task}" type="std::shared_ptr&lt;project11_navigation::Task&gt;">Survey area Task describing area to survey</input_port>
            <input_port name="action_client" default="{multibeam_coverage_action_client}" type="std::shared_ptr&lt;project11_navigation::MultibeamCoverageActionClient&gt;">Multibeam coverage action client</input_port>
        </Action>
        <Action ID="NavigatorSettingsLoader">
            <output_port name="maximum_cross_track_error" default="{maximum_cross_track_error}" type="double">Maximum cross track error in meters beyond which the robot may be considered off course</output_port>
            <output_port name="survey_lead_in_distance" default="{survey_lead_in_distance}" type="double">Distance in meters to lead into lines</output_port>
            <output_port name="waypoint_reached_distance" default="{waypoint_reached_distance}" type="double">Distance in meters to consider the waypoint reached</output_port>
        </Action>
        <Condition ID="PlanNeededCondition">
            <input_port name="maximum_cross_track_error" type="double"/>
            <input_port name="cross_track_error" type="double"/>
            <input_port name="navigation_trajectory" type="std::shared_ptr&lt;std::vector&lt;geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt;, std::allocator&lt;geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt; &gt; &gt; &gt;"/>
            <input_port name="goal_pose" type="geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt;"/>
        </Condition>
        <Action ID="PredictStoppingPose">
            <output_port name="pose" default="{pose}" type="geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt;">Predicted stopping pose</output_port>
            <input_port name="deceleration" default="{robot_default_deceleration}" type="geometry_msgs::msg::Accel_&lt;std::allocator&lt;void&gt; &gt;">Deceleration to use to predict stopping pose</input_port>
            <input_port name="odometry" default="{odometry}" type="nav_msgs::msg::Odometry_&lt;std::allocator&lt;void&gt; &gt;">Robot's current odometry state</input_port>
        </Action>
        <Action ID="RobotCapabilitiesLoader">
            <output_port name="stopping_distance" default="{robot_stopping_distance}" type="double"/>
            <input_port name="context" default="{context}" type="std::shared_ptr&lt;project11_navigation::Context&gt;">Navigation context</input_port>
            <output_port name="turn_radius" default="{robot_turn_radius}" type="double">Default turn radius</output_port>
            <output_port name="footprint" default="{robot_footprint}" type="geometry_msgs::msg::Polygon_&lt;std::allocator&lt;void&gt; &gt;"/>
            <output_port name="radius" default="{robot_radius}" type="double"/>
            <output_port name="maximum_velocity" default="{robot_maximum_velocity}" type="geometry_msgs::msg::Twist_&lt;std::allocator&lt;void&gt; &gt;"/>
            <output_port name="minimum_velocity" default="{robot_minimum_velocity}" type="geometry_msgs::msg::Twist_&lt;std::allocator&lt;void&gt; &gt;"/>
            <output_port name="default_speed" default="{robot_default_speed}" type="double"/>
            <output_port name="default_velocity" default="{robot_default_velocity}" type="geometry_msgs::msg::Twist_&lt;std::allocator&lt;void&gt; &gt;">Default cruise speed</output_port>
            <output_port name="maximum_acceleration" default="{robot_maximum_acceleration}" type="geometry_msgs::msg::Accel_&lt;std::allocator&lt;void&gt; &gt;">Maximum available acceleration</output_port>
            <output_port name="default_acceleration" default="{robot_default_acceleration}" type="geometry_msgs::msg::Accel_&lt;std::allocator&lt;void&gt; &gt;">Default acceleration that should be used for normal operations</output_port>
            <output_port name="maximum_deceleration" default="{robot_maximum_deceleration}" type="geometry_msgs::msg::Accel_&lt;std::allocator&lt;void&gt; &gt;">Powered deceleration</output_port>
            <output_port name="default_deceleration" default="{robot_default_deceleration}" type="geometry_msgs::msg::Accel_&lt;std::allocator&lt;void&gt; &gt;">Drifting deceleration</output_port>
            <output_port name="stopping_time" default="{robot_stopping_time}" type="double"/>
        </Action>
        <Action ID="SetPoseFromTask">
            <input_port name="pose_index" default="0" type="int">Index of the pose to set as output pose</input_port>
            <output_port name="pose" default="{goal_pose}" type="geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt;">Pose to set</output_port>
            <input_port name="task" default="{current_task}" type="std::shared_ptr&lt;project11_navigation::Task&gt;">Task to get pose from</input_port>
        </Action>
        <Action ID="SetTaskDone">
            <input_port name="task" default="{task}" type="std::shared_ptr&lt;project11_navigation::Task&gt;">Task to set as done</input_port>
        </Action>
        <Action ID="SetTrajectoryFromTask">
            <output_port name="current_segment" default="{current_segment}" type="int">Index of the current segment of the trajectory</output_port>
            <output_port name="trajectory" default="{current_navigation_trajectory}" type="std::shared_ptr&lt;std::vector&lt;geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt;, std::allocator&lt;geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt; &gt; &gt; &gt;">Trajectory to set</output_port>
            <input_port name="task" default="{current_task}" type="std::shared_ptr&lt;project11_navigation::Task&gt;">Task to get trajectory from</input_port>
        </Action>
        <Action ID="TaskListUpdater">
            <inout_port name="task_list" default="{task_list}" type="std::shared_ptr&lt;project11_navigation::TaskList&gt;">Pointer to the task list to update</inout_port>
            <inout_port name="task_messages" default="{task_messages}" type="std::shared_ptr&lt;std::vector&lt;project11_nav_msgs::msg::TaskInformation_&lt;std::allocator&lt;void&gt; &gt;, std::allocator&lt;project11_nav_msgs::msg::TaskInformation_&lt;std::allocator&lt;void&gt; &gt; &gt; &gt; &gt;">Pointer to a vector of new TaskInformation messages</inout_port>
        </Action>
        <Action ID="UpdateCurrentSegment">
            <output_port name="segment_count" default="{navigation_path_segment_count}" type="int">Number of segments in the path</output_port>
            <output_port name="cross_track_error" default="{current_segment_cross_track_error}" type="double">Cross track error in meters</output_port>
            <output_port name="segment_length" default="{current_segment_length}" type="double">Length of the current segment</output_port>
            <inout_port name="current_segment" default="{current_navigation_segment}" type="int">Current segment of the path</inout_port>
            <output_port name="along_track_progress" default="{current_segment_along_track_progress}" type="double">Distance along the current segment</output_port>
            <input_port name="tf_buffer" default="{tf_buffer}" type="std::shared_ptr&lt;tf2_ros::Buffer&gt;">Transform buffer</input_port>
            <input_port name="odometry" default="{odometry}" type="nav_msgs::msg::Odometry_&lt;std::allocator&lt;void&gt; &gt;">Robot's current odometry state</input_port>
            <input_port name="navigation_path" default="{navigation_path}" type="std::shared_ptr&lt;std::vector&lt;geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt;, std::allocator&lt;geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt; &gt; &gt; &gt;">Path to follow</input_port>
        </Action>
        <Action ID="UpdateCurrentTask">
            <output_port name="current_task_id" default="{current_task_id}" type="std::string">ID of the current task</output_port>
            <output_port name="current_task_type" default="{current_task_type}" type="std::string">Type of the current task</output_port>
            <output_port name="current_task" default="{current_task}" type="std::shared_ptr&lt;project11_navigation::Task&gt;">Pointer to update with current task</output_port>
            <input_port name="task_list" default="{task_list}" type="std::shared_ptr&lt;project11_navigation::TaskList&gt;">List of tasks to check</input_port>
        </Action>
        <Action ID="UpdateState">
            <output_port name="marker_array" default="{marker_array}" type="std::shared_ptr&lt;visualization_msgs::msg::MarkerArray_&lt;std::allocator&lt;void&gt; &gt; &gt;">Marker array to add visualization markers to</output_port>
            <output_port name="tf_buffer" default="{tf_buffer}" type="std::shared_ptr&lt;tf2_ros::Buffer&gt;">Transform buffer</output_port>
            <output_port name="command_velocity" default="{command_velocity}" type="geometry_msgs::msg::TwistStamped_&lt;std::allocator&lt;void&gt; &gt;">Initial command set to 0</output_port>
            <output_port name="local_costmap" default="{local_costmap}" type="std::shared_ptr&lt;project11_navigation::OccupancyGrid&gt;">Local costmap</output_port>
            <input_port name="robot_footprint" default="{robot_footprint}" type="geometry_msgs::msg::Polygon_&lt;std::allocator&lt;void&gt; &gt;">Footprint of the robot</input_port>
            <output_port name="odometry" default="{odometry}" type="nav_msgs::msg::Odometry_&lt;std::allocator&lt;void&gt; &gt;">Robot's current odometry state</output_port>
            <output_port name="base_frame" default="{base_frame}" type="std::string">Base frame_id for the robot for use with cmd_vel</output_port>
            <output_port name="piloting_mode" default="{piloting_mode}" type="std::string">Current Project11 piloting mode</output_port>
            <output_port name="current_pose" default="{current_pose}" type="geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt;">Robot's current pose</output_port>
            <input_port name="context" default="{context}" type="std::shared_ptr&lt;project11_navigation::Context&gt;">Navigation context</input_port>
        </Action>
        <Action ID="VisualizeTrajectory">
            <input_port name="current_segment" default="{current_navigation_segment}" type="int">Index of the current segment of the trajectory</input_port>
            <input_port name="future_color" default=".25, .25, .4, .5" type="std_msgs::msg::ColorRGBA_&lt;std::allocator&lt;void&gt; &gt;">Color for future segments</input_port>
            <input_port name="scale" default="1.0" type="double">Display size</input_port>
            <input_port name="current_pose" default="{current_pose}" type="geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt;">Current pose of the robot</input_port>
            <input_port name="current_color" default="0.35, 0.35, 0.5, 0.75" type="std_msgs::msg::ColorRGBA_&lt;std::allocator&lt;void&gt; &gt;">Color for current segment</input_port>
            <input_port name="namespace" default="trajectory" type="std::string">Used in ns field of Markers</input_port>
            <input_port name="past_color" default="0.25, 0.25, 0.25, 0.5" type="std_msgs::msg::ColorRGBA_&lt;std::allocator&lt;void&gt; &gt;">Color for past segments</input_port>
            <input_port name="marker_array" default="{marker_array}" type="std::shared_ptr&lt;visualization_msgs::msg::MarkerArray_&lt;std::allocator&lt;void&gt; &gt; &gt;">Pointer to MarkerArray to add visualization markers to</input_port>
            <input_port name="trajectory" default="{navigation_trajectory}" type="std::shared_ptr&lt;std::vector&lt;geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt;, std::allocator&lt;geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt; &gt; &gt; &gt;">Trajectory to visualize</input_port>
        </Action>
    </TreeNodesModel>
</root>
