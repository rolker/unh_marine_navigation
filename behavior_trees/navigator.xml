<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4"
      main_tree_to_execute="NavigatorSequence">
  <BehaviorTree ID="FollowPath">
    <ReactiveSequence>
      <Script code="debug := false"/>
      <UpdateCurrentSegment segment_count="{navigation_path_segment_count}"
                            along_track_progress="{current_segment_along_track_progress}"
                            cross_track_error="{current_segment_cross_track_error}"
                            segment_length="{current_segment_length}"
                            current_segment="{current_navigation_segment}"
                            navigation_path="{navigation_path}"
                            context="{@context}"/>
      <VisualizeTrajectory current_segment="{current_navigation_segment}"
                           future_color=".25, .25, .4, .5"
                           scale="1.0"
                           current_color=".35, .35, .5, .75"
                           namespace="transit"
                           past_color=".25, .25, .25, .5"
                           marker_array="{marker_array}"
                           trajectory="{navigation_path}"
                           current_pose="{current_pose}"
                           context="{@context}"/>
      <AdjustPath adjusted_cross_track_error="{adjusted_cross_track_error}"
                  adjusted_current_segment="{adjusted_current_segment}"
                  adjusted_segment_count="{adjusted_segment_count}"
                  adjusted_path="{adjusted_path}"
                  local_costmap="{local_costmap}"
                  odometry="{odometry}"
                  turn_radius="{robot_turn_radius}"
                  tf_buffer="{tf_buffer}"
                  along_track_progress="{current_segment_along_track_progress}"
                  current_segment="{current_navigation_segment}"
                  adjusted_along_track_progress="{adjusted_along_track_progress}"
                  path="{navigation_path}"/>
      <VisualizeTrajectory name="VisualizeAdjustedTrajectory"
                           current_segment="{adjusted_current_segment}"
                           future_color=".15, .45, .2, .5"
                           scale="2.0"
                           current_color=".25, .55, .5, .75"
                           namespace="adjusted_transit"
                           past_color=".35, .25, .15, .5"
                           marker_array="{marker_array}"
                           trajectory="{adjusted_path}"
                           current_pose="{current_pose}"
                           context="{@context}"
                           _skipIf="debug != true"/>
      <ReactiveFallback>
        <BaxevaniController command_velocity="{command_velocity}"
                            delta="0.1"
                            maximum_dt="0.5"
                            px_gain="0.1"
                            ricatti_parameter="0.1"
                            pw_gain="0.025"
                            target_speed="{target_speed}"
                            tf_buffer="{tf_buffer}"
                            current_navigation_segment="{current_navigation_segment}"
                            odometry="{odometry}"
                            navigation_path="{navigation_path}"
                            _failureIf="controller != &apos;baxevani&apos;"/>
        <CrabbingPathFollower pid="{path_follower_pid}"
                              command_velocity="{command_velocity}"
                              target_speed="{target_speed}"
                              current_navigation_segment="{current_navigation_segment}"
                              navigation_path="{navigation_path}"
                              context="{@context}"
                              _failureIf="controller != &apos;crabbing_path_follower&apos;"/>
        <AlwaysFailure/>
      </ReactiveFallback>
    </ReactiveSequence>
  </BehaviorTree>

  <BehaviorTree ID="GotoTask">
    <ReactiveSequence>
      <SetPoseFromTask pose_index="0"
                       pose="{goal_pose}"
                       task="{current_task}"
                       context="{@context}"/>
      <Fallback>
        <Inverter>
          <SubTree ID="TransitTo"
                   tf_buffer="{=}"
                   odometry="{=}"
                   goal_pose="{=}"
                   current_pose="{=}"
                   lead_in_distance="{=}"
                   robot_turn_radius="{=}"
                   default_planner="{=}"
                   context="{=}"
                   robot_default_speed="{=}"
                   navigation_state="{=}"
                   current_transit_segment="{=}"
                   transit_path="{=}"
                   _autoremap="true"/>
        </Inverter>
        <SetTaskDone task="{current_task}"/>
      </Fallback>
    </ReactiveSequence>
  </BehaviorTree>

  <BehaviorTree ID="HoverTask">
    <Sequence>
      <Fallback name="SetHoverGoalFallback">
        <SetPoseFromTask name="SetGoalPoseFromHoverTask"
                         pose_index="0"
                         pose="{goal_pose}"
                         task="{current_task}"
                         context="{@context}"/>
        <PredictStoppingPose pose="{goal_pose}"
                             deceleration="{robot_default_deceleration}"
                             odometry="{odometry}"/>
      </Fallback>
      <Script name="SetHoverParametersScript"
              code="hover_minimum_distance := robot_radius*1.25; hover_maximum_distance := robot_radius*1.25+robot_stopping_distance*1.25; hover_maximum_speed := robot_default_speed*0.75"/>
      <KeepRunningUntilFailure>
        <ReactiveFallback>
          <ForceFailure>
            <Script code="navigation_state := &quot;hover&quot;"/>
          </ForceFailure>
          <Hover marker_array="{marker_array}"
                 goal_pose="{goal_pose}"
                 maximum_speed="{hover_maximum_speed}"
                 maximum_distance="{hover_maximum_distance}"
                 minimum_distance="{hover_minimum_distance}"
                 command_velocity="{command_velocity}"
                 context="{@context}"/>
          <SubTree ID="TransitTo"
                   name="TransitToHover"
                   tf_buffer="{=}"
                   odometry="{=}"
                   goal_pose="{=}"
                   current_pose="{=}"
                   lead_in_distance="{=}"
                   robot_turn_radius="{=}"
                   default_planner="{=}"
                   context="{=}"
                   robot_default_speed="{=}"
                   navigation_state="{=}"
                   waypoint_reached_distance="{hover_maximum_distance}"
                   _autoremap="true"/>
        </ReactiveFallback>
      </KeepRunningUntilFailure>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="NavigatorSequence">
    <Sequence name="InitializeAndRunSequence">
      <TaskListUpdater task_list="{task_list}"
                       task_messages="{task_messages}"
                       context="{@context}"
                       _description="If task_messages is not empty, updates or creates a TaskList from a list of TaskInformation messages then clears task_messages and returns Success.&#10;Returns Failure if task_messages is empty."/>
      <WhileDoElse>
        <AllTasksDoneCondition task_list="{task_list}"/>
        <AlwaysSuccess/>
        <KeepRunningUntilFailure>
          <ReactiveSequence name="MainRunSequence">
            <SubTree ID="UpdateCurrentTaskData"
                     task_list="{task_list}"
                     current_task_id="{current_task_id}"
                     current_task_type="{current_task_type}"
                     current_task="{current_task}"
                     active_task_id="{active_task_id}"
                     target_speed="{target_speed}"
                     robot_default_speed="{robot_default_speed}"
                     controller="{controller}"
                     default_controller="{default_controller}"
                     planner="{planner}"
                     default_planner="{default_planner}"/>
            <ReactiveFallback name="RunTaskByType">
              <SubTree ID="HoverTask"
                       current_task="{=}"
                       odometry="{=}"
                       robot_default_deceleration="{=}"
                       robot_radius="{=}"
                       robot_stopping_distance="{=}"
                       robot_default_speed="{=}"
                       marker_array="{=}"
                       tf_buffer="{=}"
                       command_velocity="{=}"
                       current_pose="{=}"
                       lead_in_distance="0.0"
                       robot_turn_radius="{=}"
                       default_planner="{=}"
                       context="{=}"
                       navigation_state="{=}"
                       _failureIf="current_task_type != &apos;hover&apos;"
                       _autoremap="true"/>
              <SubTree ID="GotoTask"
                       current_task="{=}"
                       lead_in_distance="0.0"
                       _failureIf="current_task_type != &quot;goto&quot;"
                       _autoremap="true"/>
              <SubTree ID="SurveyLineTask"
                       lead_in_distance="{survey_lead_in_distance}"
                       survey_line_task="{current_task}"
                       _failureIf="current_task_type != &apos;survey_line&apos;"
                       _autoremap="true"/>
              <SubTree ID="SurveyLineSetTask"
                       survey_line_set_task="{current_task}"
                       _failureIf="current_task_type != &apos;survey_line_set&apos;"
                       _autoremap="true"/>
              <SubTree ID="SurveyAreaTask"
                       survey_area_task="{current_task}"
                       _failureIf="current_task_type != &apos;survey_area&apos;"
                       _autoremap="true"/>
              <SetTaskDone name="SkipUnknownTaskType"
                           task="{current_task}"/>
            </ReactiveFallback>
          </ReactiveSequence>
        </KeepRunningUntilFailure>
      </WhileDoElse>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="SurveyAreaTask">
    <Sequence>
      <GetTaskDataString value="{coverage_generator}"
                         default_value="none"
                         key="coverage_generator"
                         task="{survey_area_task}"/>
      <Sequence>
        <IfThenElse>
          <ScriptCondition code="coverage_generator == &apos;manda&apos;"/>
          <Sequence>
            <MultibeamCoverageActionSetGoal name="MandaMultibeamCoverageAction"
                                            action_client="{multibeam_coverage_action_client}"
                                            ros_action="survey_area_action"
                                            task="{survey_area_task}"
                                            context="{@context}"/>
            <ReactiveSequence>
              <MultibeamCoverageActionUpdateTask task="{survey_area_task}"
                                                 action_client="{multibeam_coverage_action_client}"
                                                 context="{@context}"/>
              <GetSubTasks sub_tasks="{survey_area_tasks}"
                           task="{survey_area_task}"/>
              <WhileDoElse>
                <ReactiveSequence>
                  <MultibeamCoverageActionDoneCondition action_client="{multibeam_coverage_action_client}"/>
                  <AllTasksDoneCondition task_list="{survey_area_tasks}"/>
                </ReactiveSequence>
                <SetTaskDone task="{survey_area_task}"/>
                <KeepRunningUntilFailure>
                  <ReactiveSequence>
                    <SubTree ID="UpdateCurrentTaskData"
                             task_list="{survey_area_tasks}"
                             current_task_id="{current_survey_area_task_id}"
                             current_task_type="{current_survey_area_task_type}"
                             current_task="{current_survey_area_task}"
                             active_task_id="{=}"
                             target_speed="{=}"
                             robot_default_speed="{=}"
                             controller="{=}"
                             default_controller="{=}"
                             planner="{=}"
                             default_planner="{=}"
                             current_tassk="{=}"
                             _autoremap="true"/>
                    <IfThenElse>
                      <ScriptCondition code="current_survey_area_task_type == &apos;survey_line&apos;"/>
                      <SubTree ID="SurveyLineTask"
                               survey_line_task="{current_survey_area_task}"
                               lead_in_distance="{survey_lead_in_distance}"
                               _autoremap="true"/>
                      <AlwaysSuccess/>
                    </IfThenElse>
                  </ReactiveSequence>
                </KeepRunningUntilFailure>
              </WhileDoElse>
            </ReactiveSequence>
          </Sequence>
          <ReactiveSequence>
            <GetSubTasks sub_tasks="{survey_area_tasks}"
                         task="{survey_area_task}"/>
            <WhileDoElse>
              <AllTasksDoneCondition task_list="{survey_area_tasks}"/>
              <SetTaskDone task="{survey_area_task}"/>
              <KeepRunningUntilFailure>
                <ReactiveSequence>
                  <SubTree ID="UpdateCurrentTaskData"
                           task_list="{survey_area_tasks}"
                           current_task_id="{current_survey_area_task_id}"
                           current_task_type="{current_survey_area_task_type}"
                           current_task="{current_survey_area_task}"
                           active_task_id="{=}"
                           target_speed="{=}"
                           robot_default_speed="{=}"
                           controller="{=}"
                           default_controller="{=}"
                           planner="{=}"
                           default_planner="{=}"
                           current_tassk="{=}"
                           _autoremap="true"/>
                  <ReactiveFallback>
                    <SubTree ID="SurveyLineTask"
                             lead_in_distance="{survey_lead_in_distance}"
                             current_task="{current_survey_area_task}"
                             _failureIf="current_survey_area_task_type != &apos;survey_line&apos;"
                             _autoremap="true"/>
                    <SubTree ID="SurveyLineSetTask"
                             name="SurveyAreaSurveyLineSetTask"
                             survey_line_set_task="{current_survey_area_task}"
                             _failureIf="current_survey_area_task_type != &apos;survey_line_set&apos;"
                             _autoremap="true"/>
                    <SetTaskDone task="{current_survey_area_task}"/>
                  </ReactiveFallback>
                </ReactiveSequence>
              </KeepRunningUntilFailure>
            </WhileDoElse>
          </ReactiveSequence>
        </IfThenElse>
        <SetTaskDone task="{survey_area_task}"/>
      </Sequence>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="SurveyLine">
    <Sequence>
      <WhileDoElse>
        <Inverter>
          <GoalReachedCondition heading_accuracy="180"
                                waypoint_reached_distance="{waypoint_reached_distance}"
                                goal_pose="{start_pose}"
                                odometry="{odometry}"/>
        </Inverter>
        <SubTree ID="TransitTo"
                 name="TransitToStartOfSurveyLine"
                 tf_buffer="{=}"
                 odometry="{=}"
                 goal_pose="{start_pose}"
                 current_pose="{=}"
                 lead_in_distance="{survey_lead_in_distance}"
                 robot_turn_radius="{=}"
                 default_planner="{=}"
                 context="{=}"
                 robot_default_speed="{=}"
                 navigation_state="{=}"
                 current_transit_segment="{=}"
                 transit_path="{=}"
                 _autoremap="true"/>
        <AlwaysSuccess/>
      </WhileDoElse>
      <ReactiveSequence>
        <Script code="navigation_state := &quot;survey_line&quot;"/>
        <SubTree ID="FollowPath"
                 current_navigation_segment="{current_survey_path_segment}"
                 tf_buffer="{=}"
                 odometry="{=}"
                 navigation_path="{survey_path}"
                 command_velocity="{=}"
                 _autoremap="true"/>
      </ReactiveSequence>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="SurveyLineSetTask">
    <ReactiveSequence>
      <GetSubTasks sub_tasks="{survey_line_set_sub_tasks}"
                   task="{survey_line_set_task}"/>
      <WhileDoElse>
        <AllTasksDoneCondition task_list="{survey_line_set_sub_tasks}"/>
        <SetTaskDone task="{survey_line_set_task}"/>
        <KeepRunningUntilFailure>
          <ReactiveSequence>
            <SubTree ID="UpdateCurrentTaskData"
                     task_list="{survey_line_set_sub_tasks}"
                     current_task_id="{survey_line_set_sub_task_id}"
                     current_task_type="{survey_line_set_sub_task_type}"
                     current_task="{survey_line_set_sub_task}"
                     active_task_id="{=}"
                     target_speed="{=}"
                     robot_default_speed="{=}"
                     controller="{=}"
                     default_controller="{=}"
                     planner="{=}"
                     default_planner="{=}"
                     current_tassk="{=}"
                     _autoremap="true"/>
            <ReactiveFallback>
              <SubTree ID="SurveyLineTask"
                       name="SurveyLineSetSurveyLineTask"
                       survey_line_task="{survey_line_set_sub_task}"
                       _failureIf="survey_line_set_sub_task_type != &apos;survey_line&apos;"
                       _autoremap="true"/>
              <SetTaskDone task="{survey_line_set_sub_task}"/>
            </ReactiveFallback>
          </ReactiveSequence>
        </KeepRunningUntilFailure>
      </WhileDoElse>
    </ReactiveSequence>
  </BehaviorTree>

  <BehaviorTree ID="SurveyLineTask">
    <Sequence>
      <SetPoseFromTask pose_index="0"
                       pose="{start_pose}"
                       task="{survey_line_task}"
                       context="{@context}"/>
      <SetTrajectoryFromTask current_segment="{current_survey_path_segment}"
                             trajectory="{survey_path}"
                             task="{survey_line_task}"/>
      <SubTree ID="SurveyLine"
               _autoremap="true"/>
      <SetTaskDone task="{survey_line_task}"/>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="TransitTo">
    <Sequence>
      <ClearPath navigation_path="{transit_path}"/>
      <ReactiveFallback>
        <GoalReachedCondition name="TransitGoalReachedCondition"
                              heading_accuracy="180"
                              waypoint_reached_distance="{waypoint_reached_distance}"
                              goal_pose="{goal_pose}"
                              odometry="{odometry}"/>
        <ReactiveSequence>
          <Script code="navigation_state := &quot;transit&quot;"/>
          <IfThenElse>
            <ReactiveSequence name="PlanIsValidReactiveSequence">
              <UpdateCurrentSegment segment_count="{transit_path_segment_count}"
                                    along_track_progress="{current_transit_segment_along_track_progress}"
                                    cross_track_error="{current_transit_segment_cross_track_error}"
                                    segment_length="{current_transit_segment_length}"
                                    current_segment="{current_transit_segment}"
                                    navigation_path="{transit_path}"
                                    context="{@context}"/>
              <AlwaysSuccess name="CrossTrackErrorCheck"
                             _failureIf="current_transit_segment_cross_track_error &gt; maximum_cross_track_error"/>
              <AlwaysSuccess name="PastLastSegmentCheck"
                             _failureIf="current_transit_segment &gt;= transit_path_segment_count"/>
            </ReactiveSequence>
            <AlwaysSuccess/>
            <Fallback>
              <GeneratePlan navigation_trajectory="{transit_path}"
                            lead_in_distance="{lead_in_distance}"
                            current_navigation_segment="{current_transit_segment}"
                            turn_radius="{robot_turn_radius}"
                            planner="{default_planner}"
                            goal_pose="{goal_pose}"
                            start_pose="{current_pose}"/>
              <CCOMPlanner start_pose="{current_pose}"
                           goal_pose="{goal_pose}"
                           navigation_path="{transit_path}"
                           turn_radius="{robot_turn_radius}"
                           tf_buffer="{tf_buffer}"
                           context="{context}"
                           speed="{robot_default_speed}"
                           _skipIf="planner != &quot;ccom_planner&quot;"/>
            </Fallback>
          </IfThenElse>
          <SubTree ID="FollowPath"
                   name="TransitFollowPath"
                   current_navigation_segment="{current_transit_segment}"
                   tf_buffer="{=}"
                   odometry="{=}"
                   navigation_path="{transit_path}"
                   command_velocity="{=}"
                   _autoremap="true"/>
        </ReactiveSequence>
      </ReactiveFallback>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="UpdateCurrentTaskData">
    <Sequence>
      <UpdateCurrentTask current_task_id="{current_task_id}"
                         current_task_type="{current_task_type}"
                         current_task="{current_task}"
                         task_list="{task_list}"
                         _onSuccess="active_task_id := current_task_id"/>
      <GetTaskDataDouble value="{target_speed}"
                         default_value="{robot_default_speed}"
                         key="speed"
                         task="{current_task}"/>
      <GetTaskDataString value="{controller}"
                         default_value="{default_controller}"
                         key="controller"
                         task="{current_task}"/>
      <GetTaskDataString value="{planner}"
                         default_value="{default_planner}"
                         key="planner"
                         task="{current_task}"/>
    </Sequence>
  </BehaviorTree>

  <!-- Description of Node Models (used by Groot) -->
  <TreeNodesModel>
    <Action ID="AdjustPath">
      <output_port name="adjusted_cross_track_error"
                   default="{adjusted_cross_track_error}"
                   type="double">Cross-track error on adjusted segment</output_port>
      <output_port name="adjusted_current_segment"
                   default="{adjusted_current_segment}"
                   type="int">Current segment of the adjusted path</output_port>
      <output_port name="adjusted_segment_count"
                   default="{adjusted_segment_count}"
                   type="int">Number of segment in adjusted path</output_port>
      <output_port name="adjusted_path"
                   default="{adjusted_path}"
                   type="std::shared_ptr&lt;std::vector&lt;geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt;, std::allocator&lt;geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt; &gt; &gt; &gt;">Path modified to avoid obstacles</output_port>
      <input_port name="local_costmap"
                  default="{local_costmap}"
                  type="std::shared_ptr&lt;project11_navigation::OccupancyGrid&gt;">Local costmap used to adjust trajectory</input_port>
      <input_port name="odometry"
                  default="{odometry}"
                  type="nav_msgs::msg::Odometry_&lt;std::allocator&lt;void&gt; &gt;">Robot's current odometry state</input_port>
      <input_port name="turn_radius"
                  default="{turn_radius}"
                  type="double">Robot's turn radius</input_port>
      <input_port name="tf_buffer"
                  default="{tf_buffer}"
                  type="std::shared_ptr&lt;tf2_ros::Buffer&gt;">Transform buffer</input_port>
      <input_port name="along_track_progress"
                  default="{current_segment_along_track_progress}"
                  type="double">How far along the current segment we are</input_port>
      <input_port name="current_segment"
                  default="{current_segment}"
                  type="int">Current path segment being followed</input_port>
      <output_port name="adjusted_along_track_progress"
                   default="{adjusted_along_track_progress}"
                   type="double">Progress along adjusted segment</output_port>
      <input_port name="path"
                  default="{path}"
                  type="std::shared_ptr&lt;std::vector&lt;geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt;, std::allocator&lt;geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt; &gt; &gt; &gt;">Path needing adjustment</input_port>
    </Action>
    <Condition ID="AllTasksDoneCondition">
      <input_port name="task_list"
                  default="{task_list}"
                  type="std::shared_ptr&lt;project11_navigation::TaskList&gt;">List of tasks to check</input_port>
    </Condition>
    <Action ID="BaxevaniController">
      <output_port name="command_velocity"
                   default="{command_velocity}"
                   type="geometry_msgs::msg::TwistStamped_&lt;std::allocator&lt;void&gt; &gt;">Output commanded velocity</output_port>
      <input_port name="delta"
                  default="0.1"
                  type="double">Distance of the (sonar) sensor from the center of mass/position of imu</input_port>
      <input_port name="maximum_dt"
                  default="0.5"
                  type="double">Maximum time step</input_port>
      <input_port name="px_gain"
                  default="100.78"
                  type="double">Proportional gain for the x axis</input_port>
      <input_port name="ricatti_parameter"
                  default="1.8752285"
                  type="double">Ricatti parameter</input_port>
      <input_port name="pw_gain"
                  default="20.055"
                  type="double">Proportional gain for the w axis</input_port>
      <input_port name="target_speed"
                  default="{target_speed}"
                  type="double">Target speed</input_port>
      <input_port name="tf_buffer"
                  default="{tf_buffer}"
                  type="std::shared_ptr&lt;tf2_ros::Buffer&gt;">Transform buffer</input_port>
      <input_port name="current_navigation_segment"
                  default="{current_navigation_segment}"
                  type="int">Current segment of the path to follow</input_port>
      <input_port name="odometry"
                  default="{odometry}"
                  type="nav_msgs::msg::Odometry_&lt;std::allocator&lt;void&gt; &gt;">Robot's current odometry state</input_port>
      <input_port name="navigation_path"
                  default="{navigation_path}"
                  type="std::shared_ptr&lt;std::vector&lt;geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt;, std::allocator&lt;geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt; &gt; &gt; &gt;">Path to follow</input_port>
    </Action>
    <Action ID="CCOMPlanner"
            editable="true">
      <input_port name="start_pose"
                  default="{start_pose}"/>
      <input_port name="goal_pose"
                  default="{goal_pose}"/>
      <output_port name="navigation_path"
                   default="{navigation_path}"/>
      <input_port name="turn_radius"
                  default="{robot_turn_radius}"/>
      <input_port name="tf_buffer"
                  default="{tf_buffer}"/>
      <input_port name="context"
                  default="{context}"/>
      <input_port name="speed"
                  default="{robot_default_speed}"/>
    </Action>
    <Action ID="ClearPath">
      <output_port name="navigation_path"
                   default="{navigation_path}"
                   type="std::shared_ptr&lt;std::vector&lt;geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt;, std::allocator&lt;geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt; &gt; &gt; &gt;">Empty shared pointer to a path to follow</output_port>
    </Action>
    <Action ID="CrabbingPathFollower">
      <inout_port name="pid"
                  default="{path_follower_pid}"
                  type="std::shared_ptr&lt;project11::PID&gt;">PID controller for crabbing</inout_port>
      <output_port name="command_velocity"
                   default="{command_velocity}"
                   type="geometry_msgs::msg::TwistStamped_&lt;std::allocator&lt;void&gt; &gt;">Output commanded velocity</output_port>
      <input_port name="target_speed"
                  default="{target_speed}"
                  type="double">Target speed</input_port>
      <input_port name="current_navigation_segment"
                  default="{current_navigation_segment}"
                  type="int">Current segment of the path</input_port>
      <input_port name="navigation_path"
                  default="{navigation_path}"
                  type="std::shared_ptr&lt;std::vector&lt;geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt;, std::allocator&lt;geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt; &gt; &gt; &gt;">Path to follow</input_port>
      <input_port name="context"
                  default="{@context}"
                  type="std::shared_ptr&lt;project11_navigation::Context&gt;">Navigation context</input_port>
    </Action>
    <SubTree ID="FollowPath"
             editable="true">
      <inout_port name="current_navigation_segment"
                  default="{=}">Index of the current segment of the navigation path.</inout_port>
