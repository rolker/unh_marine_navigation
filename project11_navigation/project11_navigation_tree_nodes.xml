<root BTCPP_format="4">
    <TreeNodesModel>
        <Condition ID="AllTasksDoneCondition">
            <input_port name="task_list" type="std::shared_ptr&lt;project11_navigation::TaskList&gt;" default="{task_list}">List of tasks to check</input_port>
        </Condition>
        <Action ID="BaxevaniController">
            <output_port name="command_velocity" type="geometry_msgs::msg::TwistStamped_&lt;std::allocator&lt;void&gt; &gt;" default="{command_velocity}">Output commanded velocity</output_port>
            <input_port name="delta" type="double" default="0.1">Distance of the (sonar) sensor from the center of mass/position of imu</input_port>
            <input_port name="maximum_dt" type="double" default="0.5">Maximum time step</input_port>
            <input_port name="px_gain" type="double" default="100.78">Proportional gain for the x axis</input_port>
            <input_port name="ricatti_parameter" type="double" default="1.8752285">Ricatti parameter</input_port>
            <input_port name="pw_gain" type="double" default="20.055">Proportional gain for the w axis</input_port>
            <input_port name="target_speed" type="double" default="{target_speed}">Target speed</input_port>
            <input_port name="current_navigation_segment" type="int" default="{current_navigation_segment}">Current segment of the path to follow</input_port>
            <input_port name="navigation_path" type="std::vector&lt;geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt;, std::allocator&lt;geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt; &gt; &gt;" default="{navigation_path}">Path to follow</input_port>
            <input_port name="context" type="std::shared_ptr&lt;project11_navigation::Context&gt;" default="{@context}">Navigation context</input_port>
        </Action>
        <Action ID="CancelFollowPath">
            <input_port name="server_timeout" type="std::chrono::milliseconds"/>
            <input_port name="server_name" type="std::string">Action server name</input_port>
        </Action>
        <Action ID="CancelHover">
            <input_port name="server_timeout" type="std::chrono::milliseconds"/>
            <input_port name="server_name" type="std::string">Action server name</input_port>
        </Action>
        <Action ID="CancelMultibeamCoverage">
            <input_port name="server_timeout" type="std::chrono::milliseconds"/>
            <input_port name="server_name" type="std::string">Action server name</input_port>
        </Action>
        <Action ID="ClearPath">
            <output_port name="navigation_path" type="nav_msgs::msg::Path_&lt;std::allocator&lt;void&gt; &gt;" default="{navigation_path}">Empty shared pointer to a path to follow</output_port>
        </Action>
        <Action ID="CrabbingPathFollower">
            <inout_port name="pid" type="std::shared_ptr&lt;project11::PID&gt;" default="{path_follower_pid}">PID controller for crabbing</inout_port>
            <output_port name="command_velocity" type="geometry_msgs::msg::TwistStamped_&lt;std::allocator&lt;void&gt; &gt;" default="{command_velocity}">Output commanded velocity</output_port>
            <input_port name="target_speed" type="double" default="{target_speed}">Target speed</input_port>
            <input_port name="current_navigation_segment" type="int" default="{current_navigation_segment}">Current segment of the path</input_port>
            <input_port name="navigation_path" type="std::vector&lt;geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt;, std::allocator&lt;geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt; &gt; &gt;" default="{navigation_path}">Path to follow</input_port>
            <input_port name="context" type="std::shared_ptr&lt;project11_navigation::Context&gt;" default="{@context}">Navigation context</input_port>
        </Action>
        <Action ID="DebugBlackboardDouble">
            <input_port name="value" type="double">Value to print in the ROS log</input_port>
            <input_port name="message" type="std::string" default="message">Message to print, such as the variable name</input_port>
            <input_port name="context" type="std::shared_ptr&lt;project11_navigation::Context&gt;" default="{@context}">Navigation context</input_port>
        </Action>
        <Action ID="DebugBlackboardString">
            <input_port name="value" type="std::string">Value to print in the ROS log</input_port>
            <input_port name="message" type="std::string" default="message">Message to print, such as the variable name</input_port>
            <input_port name="context" type="std::shared_ptr&lt;project11_navigation::Context&gt;" default="{@context}">Navigation context</input_port>
        </Action>
        <Action ID="GeneratePlan">
            <output_port name="navigation_trajectory" type="std::vector&lt;geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt;, std::allocator&lt;geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt; &gt; &gt;" default="{navigation_trajectory}">Planned path to follow</output_port>
            <output_port name="current_navigation_segment" type="int" default="{current_navigation_segment}">Index of the current segment of the navigation trajectory</output_port>
            <input_port name="planner" type="std::string" default="{default_planner}">Planner to use</input_port>
            <input_port name="use_lead_in" type="bool" default="true">Use lead in distance</input_port>
            <input_port name="goal_pose" type="geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt;" default="{goal_pose}">Goal pose for the plan</input_port>
            <input_port name="start_pose" type="geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt;" default="{current_pose}">Starting pose for the plan</input_port>
            <input_port name="context" type="std::shared_ptr&lt;project11_navigation::Context&gt;" default="{@context}">Navigation context</input_port>
        </Action>
        <Action ID="GetSubPath">
            <output_port name="output_path" type="nav_msgs::msg::Path_&lt;std::allocator&lt;void&gt; &gt;">Sub-path as nav_msgs/msg/Path</output_port>
            <input_port name="end_index" type="int" default="-1">Index of the last pose in the trajectory</input_port>
            <input_port name="start_index" type="int" default="0">Index of the first pose in the trajectory</input_port>
            <input_port name="input_path" type="nav_msgs::msg::Path_&lt;std::allocator&lt;void&gt; &gt;">Input path as nav_msgs/msg/Path</input_port>
        </Action>
        <Action ID="GetSubTasks">
            <output_port name="sub_tasks" type="std::shared_ptr&lt;project11_navigation::TaskList&gt;" default="{current_sub_tasks}">Sub tasks of the input task</output_port>
            <input_port name="task" type="std::shared_ptr&lt;project11_navigation::Task&gt;" default="{current_task}">Task to get sub tasks from</input_port>
        </Action>
        <Action ID="GetTaskDataDouble">
            <output_port name="value" type="double"/>
            <input_port name="default_value" type="double"/>
            <input_port name="key" type="std::string"/>
            <input_port name="task" type="std::shared_ptr&lt;project11_navigation::Task&gt;" default="{task}">Task to get data from</input_port>
        </Action>
        <Action ID="GetTaskDataString">
            <output_port name="value" type="std::string"/>
            <input_port name="default_value" type="std::string"/>
            <input_port name="key" type="std::string"/>
            <input_port name="task" type="std::shared_ptr&lt;project11_navigation::Task&gt;" default="{task}">Task to get data from</input_port>
        </Action>
        <Condition ID="GoalReachedCondition">
            <input_port name="goal_reached_distance" type="double" default="1.0">Distance to goal to be considered reached.</input_port>
            <input_port name="heading_accuracy" type="double" default="180">How much can the heading can vary in degrees. 180 means it doesn't matter.</input_port>
            <input_port name="goal_pose" type="geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt;" default="{goal_pose}">Pose to compare current state with</input_port>
        </Condition>
        <Condition ID="HasSubTasksCondition">
            <input_port name="task_type" type="std::string" default="">Optional type of tasks to check</input_port>
            <input_port name="task" type="std::shared_ptr&lt;project11_navigation::Task&gt;" default="{current_task}">Task to check for sub-tasks</input_port>
        </Condition>
        <Action ID="Hover">
            <input_port name="maximum_distance" type="double" default="0.000000">Distance at which robot uses maximum speed to get to the target</input_port>
            <input_port name="maximum_speed" type="double" default="0.000000">Maximum speed to use to get to the target</input_port>
            <output_port name="error_code_id" type="unsigned short">The hover server error code</output_port>
            <input_port name="server_timeout" type="std::chrono::milliseconds"/>
            <input_port name="minimum_distance" type="double" default="0.000000">Distance within which robot is deemed at the target and drifts</input_port>
            <input_port name="server_name" type="std::string">Action server name</input_port>
        </Action>
        <Action ID="MultibeamCoverage">
            <input_port name="survey_area" type="geometry_msgs::msg::PolygonStamped_&lt;std::allocator&lt;void&gt; &gt;">Area to be surveyed</input_port>
            <output_port name="current_line" type="nav_msgs::msg::Path_&lt;std::allocator&lt;void&gt; &gt;">Current survey line</output_port>
            <input_port name="server_timeout" type="std::chrono::milliseconds"/>
            <input_port name="server_name" type="std::string">Action server name</input_port>
        </Action>
        <Condition ID="PathEmptyCondition">
            <input_port name="path" type="nav_msgs::msg::Path_&lt;std::allocator&lt;void&gt; &gt;" default="{path}">Path to check</input_port>
        </Condition>
        <Action ID="PathToPoseVector">
            <output_port name="poses" type="std::vector&lt;geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt;, std::allocator&lt;geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt; &gt; &gt;" default="{poses}">Vector of poses to set</output_port>
            <input_port name="path" type="nav_msgs::msg::Path_&lt;std::allocator&lt;void&gt; &gt;" default="{path}">Path to convert to pose vector</input_port>
        </Action>
        <Condition ID="PlanNeededCondition">
            <input_port name="cross_track_error" type="double"/>
            <input_port name="navigation_trajectory" type="std::vector&lt;geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt;, std::allocator&lt;geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt; &gt; &gt;"/>
            <input_port name="goal_pose" type="geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt;"/>
            <input_port name="context" type="std::shared_ptr&lt;project11_navigation::Context&gt;" default="{@context}">Navigation context</input_port>
        </Condition>
        <Action ID="PoseVectorToPath">
            <output_port name="path" type="nav_msgs::msg::Path_&lt;std::allocator&lt;void&gt; &gt;" default="{path}">Path to set</output_port>
            <input_port name="poses" type="std::vector&lt;geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt;, std::allocator&lt;geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt; &gt; &gt;" default="{poses}">Vector of poses to convert to path</input_port>
        </Action>
        <Action ID="PredictStoppingPose">
            <output_port name="pose" type="geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt;" default="{pose}">Predicted stopping pose</output_port>
            <input_port name="context" type="std::shared_ptr&lt;project11_navigation::Context&gt;" default="{@context}">Navigation context</input_port>
        </Action>
        <Action ID="SetPathFromTask">
            <input_port name="end_index" type="int" default="-1">Index of the last pose in the navigation path</input_port>
            <output_port name="path" type="nav_msgs::msg::Path_&lt;std::allocator&lt;void&gt; &gt;" default="{current_navigation_path}">Navigation path to set</output_port>
            <input_port name="start_index" type="int" default="0">Index of the first pose in the navigation path</input_port>
            <input_port name="task" type="std::shared_ptr&lt;project11_navigation::Task&gt;" default="{current_task}">Task to get navigation path from</input_port>
        </Action>
        <Action ID="SetPolygonFromTask">
            <output_port name="polygon" type="geometry_msgs::msg::PolygonStamped_&lt;std::allocator&lt;void&gt; &gt;">Polygon to set</output_port>
            <input_port name="end_index" type="int" default="-1">Index of the last pose in the polygon</input_port>
            <input_port name="start_index" type="int" default="0">Index of the first pose describing the polygon</input_port>
            <input_port name="task" type="std::shared_ptr&lt;project11_navigation::Task&gt;" default="{current_task}">Task to get polygon from</input_port>
        </Action>
        <Action ID="SetPoseFromTask">
            <output_port name="out_of_range_flag" type="bool" default="{index_out_of_range_flag}">Flag to indicate if the pose index is out of range</output_port>
            <input_port name="pose_index" type="int" default="0">Index of the pose to set as output pose</input_port>
            <output_port name="pose" type="geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt;" default="{goal_pose}">Pose to set</output_port>
            <input_port name="task" type="std::shared_ptr&lt;project11_navigation::Task&gt;" default="{current_task}">Task to get pose from</input_port>
        </Action>
        <Action ID="SetTaskDone">
            <input_port name="task" type="std::shared_ptr&lt;project11_navigation::Task&gt;" default="{task}">Task to set as done</input_port>
        </Action>
        <Action ID="SetTrajectoryFromTask">
            <output_port name="trajectory" type="std::vector&lt;geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt;, std::allocator&lt;geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt; &gt; &gt;" default="{current_navigation_trajectory}">Trajectory to set</output_port>
            <input_port name="end_index" type="int" default="-1">Index of the last pose in the trajectory</input_port>
            <input_port name="start_index" type="int" default="0">Index of the first pose in the trajectory</input_port>
            <input_port name="task" type="std::shared_ptr&lt;project11_navigation::Task&gt;" default="{current_task}">Task to get trajectory from</input_port>
        </Action>
        <Action ID="TaskListUpdater">
            <inout_port name="task_list" type="std::shared_ptr&lt;project11_navigation::TaskList&gt;" default="{task_list}">Pointer to the task list to update</inout_port>
            <inout_port name="task_messages" type="std::shared_ptr&lt;std::vector&lt;project11_nav_msgs::msg::TaskInformation_&lt;std::allocator&lt;void&gt; &gt;, std::allocator&lt;project11_nav_msgs::msg::TaskInformation_&lt;std::allocator&lt;void&gt; &gt; &gt; &gt; &gt;" default="{task_messages}">Pointer to a vector of new TaskInformation messages</inout_port>
            <input_port name="context" type="std::shared_ptr&lt;project11_navigation::Context&gt;" default="{@context}">Navigation context</input_port>
        </Action>
        <Condition ID="TaskUpdatedCondition">
            <input_port name="last_update_time" type="rclcpp::Time" default="{last_update_time}">Last update time to compare against</input_port>
            <input_port name="task" type="std::shared_ptr&lt;project11_navigation::Task&gt;" default="{task}">Task to check for updates</input_port>
        </Condition>
        <Action ID="UpdateCurrentSegment">
            <output_port name="segment_count" type="int" default="{navigation_path_segment_count}">Number of segments in the path</output_port>
            <output_port name="along_track_progress" type="double" default="{current_segment_along_track_progress}">Distance along the current segment</output_port>
            <output_port name="cross_track_error" type="double" default="{current_segment_cross_track_error}">Cross track error in meters</output_port>
            <output_port name="segment_length" type="double" default="{current_segment_length}">Length of the current segment</output_port>
            <inout_port name="current_segment" type="int" default="{current_navigation_segment}">Current segment of the path</inout_port>
            <input_port name="navigation_path" type="std::vector&lt;geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt;, std::allocator&lt;geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt; &gt; &gt;" default="{navigation_path}">Path to follow</input_port>
            <input_port name="context" type="std::shared_ptr&lt;project11_navigation::Context&gt;" default="{@context}">Navigation context</input_port>
        </Action>
        <Action ID="UpdateCurrentTask">
            <output_port name="current_task_update_time" type="rclcpp::Time" default="{current_task_update_time}">Time the current task was last updated</output_port>
            <output_port name="current_task_id" type="std::string" default="{current_task_id}">ID of the current task</output_port>
            <output_port name="current_task_type" type="std::string" default="{current_task_type}">Type of the current task</output_port>
            <output_port name="current_task" type="std::shared_ptr&lt;project11_navigation::Task&gt;" default="{current_task}">Pointer to update with current task</output_port>
            <input_port name="task_list" type="std::shared_ptr&lt;project11_navigation::TaskList&gt;" default="{task_list}">List of tasks to check</input_port>
        </Action>
        <Action ID="VisualizeTrajectory">
            <input_port name="current_segment" type="int" default="{current_navigation_segment}">Index of the current segment of the trajectory</input_port>
            <input_port name="future_color" type="std_msgs::msg::ColorRGBA_&lt;std::allocator&lt;void&gt; &gt;" default=".25, .25, .4, .5">Color for future segments</input_port>
            <input_port name="scale" type="double" default="1.0">Display size</input_port>
            <input_port name="current_color" type="std_msgs::msg::ColorRGBA_&lt;std::allocator&lt;void&gt; &gt;" default="0.35, 0.35, 0.5, 0.75">Color for current segment</input_port>
            <input_port name="namespace" type="std::string" default="trajectory">Used in ns field of Markers</input_port>
            <input_port name="past_color" type="std_msgs::msg::ColorRGBA_&lt;std::allocator&lt;void&gt; &gt;" default="0.25, 0.25, 0.25, 0.5">Color for past segments</input_port>
            <input_port name="marker_array" type="std::shared_ptr&lt;visualization_msgs::msg::MarkerArray_&lt;std::allocator&lt;void&gt; &gt; &gt;" default="{marker_array}">Pointer to MarkerArray to add visualization markers to</input_port>
            <input_port name="trajectory" type="std::vector&lt;geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt;, std::allocator&lt;geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt; &gt; &gt;" default="{navigation_trajectory}">Trajectory to visualize</input_port>
            <input_port name="current_pose" type="geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt;" default="{current_pose}">Current pose of the robot</input_port>
            <input_port name="context" type="std::shared_ptr&lt;project11_navigation::Context&gt;" default="{@context}">Navigation context</input_port>
        </Action>
    </TreeNodesModel>
</root>

